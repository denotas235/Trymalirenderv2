{
  "schemaVersion": 1,
  "id": "malioptrenderv2",
  "version": "${version}",
  "name": "MaliOptRender V2",
  "description": "Detector de extensões OpenGL e Vulkan para Mali-G52 MC2",
  "authors": ["DENOTAS"],
  "license": "CC0-1.0",
  "icon": "assets/malioptrenderv2/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "value": "com.malioptrender2v.client.Malioptrenderv2Client",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "malioptrenderv2.mixins.json",
    {
      "config": "malioptrenderv2.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  }
}
